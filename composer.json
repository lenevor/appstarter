{
	"name": "lenevor/appstarter",
	"type": "project",
	"description": "The Lenevor Framework.",
	"keywords": ["syscodes","lenevor"],
	"license": "BSD-3-Clause",
	"homepage": "https://lenevor.com",
	"support": {
		"wiki": "https://github.com/lenevor/lenevor/wiki",
		"source": "https://github.com/lenevor"
	},
	"authors": [
		{
			"name": "Alexander Campo",
			"email": "jalexcam@gmail.com"
		}
	],
	"require": {
		"php": "^8.3",
		"lenevor/syscodes": "^0.9.0"
	},
	"scripts": {
		"setup": [
			"composer install",
			"@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
			"@php prime key:generate",
			"@php prime migrate --force"
		],
		"post-root-package-install": [
			"@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
		],	
		"post-create-project-cmd": [
			"@php prime key:generate --ansi",
			"@php -r \"file_exists('database/data/database.sqlite') || touch('database/data/database.sqlite');\"",
			"@php prime migrate --graceful --ansi"
		]
	},
	"extra": {
		"lenevor": {
			"dont-discover": []
		}
	},
	"minimum-stability": "dev",
	"prefer-stable": true
}